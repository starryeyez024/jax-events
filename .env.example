# Anthropic API key — enables the AI-powered "+ Add tip" feature on the header.
# Without this, you can still add tips manually via the form. With it set,
# you can paste any Instagram caption / email / flyer text and Claude (Haiku 4.5,
# ~$0.001 per tip) extracts title, date, venue, categories.
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Ticketmaster Discovery API (optional)
# Free key at https://developer-acct.ticketmaster.com/user/register
TICKETMASTER_API_KEY=

# Meetup groups — comma-separated slugs (no leading slash).
# These show up at https://www.meetup.com/<slug>/ — Meetup auto-publishes
# an iCal feed for every public group, no auth required.
#
# Suggested Jacksonville-area starter list (verified real on 2026-05-16,
# adjust freely — remove ones you don't care about, add others you find):
#
#   philosophy / discussion:
#     jaxbookclub                  (Philosophy & Psychology Book Club)
#     philosophy-for-living
#     socraticsessions
#     modernwisdomphilosophy
#     humanistbookgroup            (First Coast Freethought)
#
#   tech / AI / design:
#     jax-node-js-ug               (JaxNode)
#     jax-women-in-technology
#     ai-safety-awareness-group-jacksonville
#     dug-jacksonville             (D365/Power Platform/AI)
#
#   yoga / wellness:
#     jacksonville-florida-yoga
#     empoweringwellness
#     inner-engineering-jacksonville-isha-yoga-meditation-classes
#     sahaja-yoga-meditation-jacksonville
#
#   dance:
#     latin-dance-jax
MEETUP_GROUPS=jaxbookclub,philosophy-for-living,socraticsessions,jax-node-js-ug,jax-women-in-technology,ai-safety-awareness-group-jacksonville,jacksonville-florida-yoga,latin-dance-jax

# Home base for distance scoring & drive-time estimates
# Default: 915 8th Ave S, Jacksonville Beach, FL 32250 (~30.2867, -81.3934)
HOME_LAT=30.2867
HOME_LON=-81.3934

# ----- Supabase (refactor-supabase branch only) -----
# Required once you migrate off SQLite. Create a project at
# https://supabase.com → Project Settings → Data API to get the URL,
# Project Settings → API keys to get both keys.
#
# NEXT_PUBLIC_* values are bundled into the browser, so use the anon key
# there only (it's safe to expose, gated by Row Level Security policies).
# The SERVICE_ROLE_KEY bypasses RLS — server-side only, never ship it.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
